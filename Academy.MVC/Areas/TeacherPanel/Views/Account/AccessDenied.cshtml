@{
    ViewData["Title"] = "Access Denied";
    Layout = "~/Areas/TeacherPanel/Views/Account/_AuthLayout.cshtml";
}

@section Styles {
<style>
    .denied-wrapper {
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 100vh;
        padding: 20px;
    }

    .denied-container {
        text-align: center;
        max-width: 600px;
        width: 100%;
        animation: fadeInScale 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
        opacity: 0;
        transform: scale(0.9);
    }

    @@keyframes fadeInScale {
        to {
            opacity: 1;
            transform: scale(1);
        }
    }

    /* Shield Icon */
    .shield-container {
        position: relative;
        width: 160px;
        height: 160px;
        margin: 0 auto 40px;
    }

    .shield-circle {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        border-radius: 50%;
        border: 2px solid;
        animation: pulseRing 2s ease-in-out infinite;
    }

    .shield-circle-1 {
        width: 160px;
        height: 160px;
        border-color: rgba(239, 68, 68, 0.15);
        animation-delay: 0s;
    }

    .shield-circle-2 {
        width: 130px;
        height: 130px;
        border-color: rgba(239, 68, 68, 0.25);
        animation-delay: 0.3s;
    }

    .shield-circle-3 {
        width: 100px;
        height: 100px;
        border-color: rgba(239, 68, 68, 0.35);
        animation-delay: 0.6s;
    }

    @@keyframes pulseRing {
        0%, 100% { transform: translate(-50%, -50%) scale(1); opacity: 1; }
        50% { transform: translate(-50%, -50%) scale(1.08); opacity: 0.6; }
    }

    .shield-icon {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        width: 72px;
        height: 72px;
        background: linear-gradient(135deg, #ef4444, #dc2626, #b91c1c);
        border-radius: 18px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 32px;
        color: white;
        box-shadow: 0 8px 40px rgba(239, 68, 68, 0.4);
        animation: iconBounce 3s ease-in-out infinite;
    }

    @@keyframes iconBounce {
        0%, 100% { transform: translate(-50%, -50%) rotate(0deg); }
        25% { transform: translate(-50%, -50%) rotate(-3deg); }
        75% { transform: translate(-50%, -50%) rotate(3deg); }
    }

    /* Glitch effect on hover */
    .shield-icon:hover {
        animation: glitchShake 0.4s ease;
    }

    @@keyframes glitchShake {
        0% { transform: translate(-50%, -50%) translate(0); }
        20% { transform: translate(-50%, -50%) translate(-4px, 2px); }
        40% { transform: translate(-50%, -50%) translate(4px, -2px); }
        60% { transform: translate(-50%, -50%) translate(-2px, -4px); }
        80% { transform: translate(-50%, -50%) translate(2px, 4px); }
        100% { transform: translate(-50%, -50%) translate(0); }
    }

    /* Error Code */
    .error-code {
        font-size: 14px;
        font-weight: 700;
        color: #ef4444;
        text-transform: uppercase;
        letter-spacing: 4px;
        margin-bottom: 16px;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 6px 16px;
        background: rgba(239, 68, 68, 0.1);
        border: 1px solid rgba(239, 68, 68, 0.2);
        border-radius: 20px;
    }

    .error-code .dot {
        width: 6px;
        height: 6px;
        background: #ef4444;
        border-radius: 50%;
        animation: blink 1.5s ease-in-out infinite;
    }

    @@keyframes blink {
        0%, 100% { opacity: 1; }
        50% { opacity: 0.2; }
    }

    /* Text Content */
    .denied-title {
        font-size: 40px;
        font-weight: 800;
        color: #ffffff;
        margin-bottom: 16px;
        letter-spacing: -1px;
        line-height: 1.2;
    }

    .denied-title span {
        background: linear-gradient(135deg, #ef4444, #f97316);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    .denied-description {
        font-size: 16px;
        line-height: 1.7;
        color: rgba(255, 255, 255, 0.5);
        margin-bottom: 40px;
        max-width: 450px;
        margin-left: auto;
        margin-right: auto;
    }

    /* Info card */
    .info-card {
        background: rgba(255, 255, 255, 0.03);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.06);
        border-radius: 16px;
        padding: 24px;
        margin-bottom: 36px;
        text-align: left;
    }

    .info-card-header {
        display: flex;
        align-items: center;
        gap: 10px;
        color: #f59e0b;
        font-size: 14px;
        font-weight: 600;
        margin-bottom: 16px;
    }

    .info-card-header i {
        font-size: 16px;
    }

    .info-list {
        list-style: none;
        padding: 0;
        margin: 0;
    }

    .info-list li {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 8px 0;
        color: rgba(255, 255, 255, 0.5);
        font-size: 13px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.04);
    }

    .info-list li:last-child {
        border-bottom: none;
    }

    .info-list li i {
        color: rgba(255, 255, 255, 0.3);
        font-size: 12px;
        width: 16px;
        text-align: center;
    }

    /* Action Buttons */
    .action-buttons {
        display: flex;
        gap: 16px;
        justify-content: center;
        flex-wrap: wrap;
    }

    .btn-action {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        padding: 14px 28px;
        border-radius: 12px;
        font-size: 15px;
        font-weight: 600;
        font-family: 'Inter', sans-serif;
        text-decoration: none;
        transition: all 0.3s ease;
        cursor: pointer;
        border: none;
    }

    .btn-primary-action {
        background: linear-gradient(135deg, #6366f1, #8b5cf6);
        color: #ffffff;
        box-shadow: 0 4px 20px rgba(99, 102, 241, 0.3);
    }

    .btn-primary-action:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 32px rgba(99, 102, 241, 0.5);
        color: #ffffff;
        text-decoration: none;
    }

    .btn-secondary-action {
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.1);
        color: rgba(255, 255, 255, 0.7);
    }

    .btn-secondary-action:hover {
        background: rgba(255, 255, 255, 0.1);
        color: #ffffff;
        text-decoration: none;
        transform: translateY(-2px);
    }

    /* Scan line animation */
    .scan-line {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 2px;
        background: linear-gradient(90deg, transparent, #ef4444, transparent);
        opacity: 0.3;
        animation: scanLine 4s linear infinite;
        z-index: 5;
        pointer-events: none;
    }

    @@keyframes scanLine {
        0% { top: -2px; }
        100% { top: 100%; }
    }

    /* Corner decorations */
    .corner-decoration {
        position: fixed;
        width: 60px;
        height: 60px;
        z-index: 5;
        pointer-events: none;
    }

    .corner-decoration::before,
    .corner-decoration::after {
        content: '';
        position: absolute;
        background: rgba(239, 68, 68, 0.3);
    }

    .corner-tl {
        top: 20px;
        left: 20px;
    }
    .corner-tl::before { width: 2px; height: 30px; top: 0; left: 0; }
    .corner-tl::after { width: 30px; height: 2px; top: 0; left: 0; }

    .corner-tr {
        top: 20px;
        right: 20px;
    }
    .corner-tr::before { width: 2px; height: 30px; top: 0; right: 0; }
    .corner-tr::after { width: 30px; height: 2px; top: 0; right: 0; }

    .corner-bl {
        bottom: 20px;
        left: 20px;
    }
    .corner-bl::before { width: 2px; height: 30px; bottom: 0; left: 0; }
    .corner-bl::after { width: 30px; height: 2px; bottom: 0; left: 0; }

    .corner-br {
        bottom: 20px;
        right: 20px;
    }
    .corner-br::before { width: 2px; height: 30px; bottom: 0; right: 0; }
    .corner-br::after { width: 30px; height: 2px; bottom: 0; right: 0; }

    /* Matrix rain effect for background */
    .matrix-column {
        position: fixed;
        top: -100%;
        font-family: 'Courier New', monospace;
        font-size: 14px;
        color: rgba(239, 68, 68, 0.08);
        writing-mode: vertical-rl;
        text-orientation: mixed;
        animation: matrixFall linear infinite;
        z-index: 1;
        pointer-events: none;
        user-select: none;
    }

    @@keyframes matrixFall {
        0% { transform: translateY(-100%); }
        100% { transform: translateY(200vh); }
    }

    /* Countdown timer */
    .countdown-text {
        margin-top: 32px;
        color: rgba(255, 255, 255, 0.25);
        font-size: 13px;
    }

    .countdown-text span {
        color: rgba(255, 255, 255, 0.5);
        font-weight: 600;
        font-variant-numeric: tabular-nums;
    }
</style>
}

<!-- Scan line effect -->
<div class="scan-line"></div>

<!-- Corner decorations for "security zone" feel -->
<div class="corner-decoration corner-tl"></div>
<div class="corner-decoration corner-tr"></div>
<div class="corner-decoration corner-bl"></div>
<div class="corner-decoration corner-br"></div>

<!-- Matrix rain columns -->
<div id="matrixRain"></div>

<div class="denied-wrapper">
    <div class="denied-container">
        <div class="shield-container">
            <div class="shield-circle shield-circle-1"></div>
            <div class="shield-circle shield-circle-2"></div>
            <div class="shield-circle shield-circle-3"></div>
            <div class="shield-icon">
                <i class="fas fa-shield-halved"></i>
            </div>
        </div>

        <div class="error-code">
            <span class="dot"></span>
            Error 403 — Forbidden
        </div>

        <h1 class="denied-title">
            <span>Access</span> Denied
        </h1>

        <p class="denied-description">
            You don't have the required permissions to enter the Teacher Portal.
            This area is restricted to authorized teaching staff only.
        </p>

        <div class="info-card">
            <div class="info-card-header">
                <i class="fas fa-info-circle"></i>
                Why am I seeing this?
            </div>
            <ul class="info-list">
                <li>
                    <i class="fas fa-chevron-right"></i>
                    Your account does not have the <strong style="color:rgba(255,255,255,0.8);">Teacher</strong> role assigned
                </li>
                <li>
                    <i class="fas fa-chevron-right"></i>
                    Only users with an active teacher profile can access this portal
                </li>
                <li>
                    <i class="fas fa-chevron-right"></i>
                    Contact your administrator if you believe this is a mistake
                </li>
            </ul>
        </div>

        <div class="action-buttons">
            <a href="@Url.Action("Login", "Account", new { area = "TeacherPanel" })" class="btn-action btn-primary-action">
                <i class="fas fa-right-to-bracket"></i>
                Try Another Account
            </a>
            <a href="/" class="btn-action btn-secondary-action">
                <i class="fas fa-house"></i>
                Go to Home
            </a>
        </div>

        <div class="countdown-text">
            Redirecting to login in <span id="countdown">15</span> seconds...
        </div>
    </div>
</div>

@section Scripts {
<script>
    // Matrix rain effect
    (function () {
        const matrixContainer = document.getElementById('matrixRain');
        const chars = '01アイウエオカキクケコ{}[]<>/\\|=-+*&^%$#@@!';
        
        for (let i = 0; i < 20; i++) {
            const column = document.createElement('div');
            column.classList.add('matrix-column');
            column.style.left = (Math.random() * 100) + '%';
            column.style.animationDuration = (Math.random() * 10 + 8) + 's';
            column.style.animationDelay = (Math.random() * 5) + 's';
            column.style.fontSize = (Math.random() * 8 + 10) + 'px';
            
            let text = '';
            for (let j = 0; j < 30; j++) {
                text += chars.charAt(Math.floor(Math.random() * chars.length)) + ' ';
            }
            column.textContent = text;
            matrixContainer.appendChild(column);
        }
    })();

    // Auto-redirect countdown
    (function () {
        let seconds = 15;
        const countdownEl = document.getElementById('countdown');
        
        const interval = setInterval(function () {
            seconds--;
            countdownEl.textContent = seconds;
            
            if (seconds <= 0) {
                clearInterval(interval);
                window.location.href = '@Url.Action("Login", "Account", new { area = "TeacherPanel" })';
            }
        }, 1000);
    })();
</script>
}
